---
import DocsLayout from '../../layouts/DocsLayout.astro';

const accents = [
  { name: 'Blue-Grey', hex: '#607D8B', bg: 'var(--lp-accent-blue-grey)' },
  { name: 'Teal',      hex: '#009688', bg: 'var(--lp-accent-teal)' },
  { name: 'Pink',      hex: '#FF4081', bg: 'var(--lp-accent-pink)' },
  { name: 'Blue',      hex: '#2196F3', bg: 'var(--lp-accent-blue)' },
  { name: 'Green',     hex: '#4CAF50', bg: 'var(--lp-accent-green)' },
  { name: 'Purple',    hex: '#9C27B0', bg: 'var(--lp-accent-purple)' },
];
---
<DocsLayout title="Colors — Accent Palette" description="Theme accents available via the portfolio's accent switcher.">
  <div class="sg-swatches grid">
    {accents.map((s) => (
      <div class="sg-swatch" style={`background:${s.bg};color:var(--lp-white)`}>
        <div>
          <div class="sg-swatch-name">{s.name}</div>
          <div class="sg-swatch-role">Accent opt-in</div>
        </div>
        <div class="sg-swatch-hex">{s.hex}</div>
      </div>
    ))}
  </div>
</DocsLayout>

<style>
  .grid { grid-template-columns: repeat(6, 1fr); }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 480px) { .grid { grid-template-columns: repeat(2, 1fr); } }
</style>
