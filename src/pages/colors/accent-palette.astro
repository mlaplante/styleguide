---
import DocsLayout from '../../layouts/DocsLayout.astro';

const accents = [
  { name: 'Blue-Grey', hex: '#607D8B', token: '--lp-accent-blue-grey' },
  { name: 'Teal', hex: '#009688', token: '--lp-accent-teal' },
  { name: 'Pink', hex: '#FF4081', token: '--lp-accent-pink' },
  { name: 'Blue', hex: '#2196F3', token: '--lp-accent-blue' },
  { name: 'Green', hex: '#4CAF50', token: '--lp-accent-green' },
  { name: 'Purple', hex: '#9C27B0', token: '--lp-accent-purple' },
];
---

<DocsLayout
  title="Colors — Accent Palette"
  description="Legacy Material accents from the portfolio's opt-in accent switcher. The current identity leads with the amber signal (see Colors — Primary); these remain only for the switcher rail. Click a token or hex value to copy it."
>
  <div class="sg-swatches grid">
    {
      accents.map((s) => (
        <div class="sg-swatch" style={`background:var(${s.token});color:var(--lp-white)`}>
          <div>
            <div class="sg-swatch-name">{s.name}</div>
            <div class="sg-swatch-role">Accent opt-in</div>
          </div>
          <div class="sg-swatch-tokens">
            <button class="sg-copy" type="button" data-copy={`var(${s.token})`}>
              {s.token}
            </button>
            <button class="sg-copy" type="button" data-copy={s.hex}>
              {s.hex}
            </button>
          </div>
        </div>
      ))
    }
  </div>
</DocsLayout>

<style>
  .grid {
    grid-template-columns: repeat(6, 1fr);
  }
  .grid :global(.sg-copy) {
    font-size: 10px;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 480px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
