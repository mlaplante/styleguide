---
import DocsLayout from '../../layouts/DocsLayout.astro';

const indigo = [
  { name: 'Indigo 500', hex: '#3F51B5', role: 'Primary / Hero',  bg: 'var(--lp-indigo-500)', fg: 'var(--lp-white)' },
  { name: 'Indigo 600', hex: '#3849A1', role: 'Hover',           bg: 'var(--lp-indigo-600)', fg: 'var(--lp-white)' },
  { name: 'Indigo 700', hex: '#303F8C', role: 'Pressed',         bg: 'var(--lp-indigo-700)', fg: 'var(--lp-white)' },
  { name: 'Indigo 10%', hex: 'rgba(63,81,181,.1)', role: 'Eyebrow wash', bg: 'var(--lp-indigo-100)', fg: 'var(--lp-indigo-500)', outline: true },
];
const blog = [
  { name: 'Blog 500',  hex: '#2980B9', role: 'Blog nav start', bg: 'var(--lp-blog-blue-500)', fg: 'var(--lp-white)' },
  { name: 'Blog 600',  hex: '#1A6DA3', role: 'Blog nav end',   bg: 'var(--lp-blog-blue-600)', fg: 'var(--lp-white)' },
  { name: 'Blog 700',  hex: '#1A5276', role: 'Dark nav',        bg: 'var(--lp-blog-blue-700)', fg: 'var(--lp-white)' },
  { name: 'Link Dark', hex: '#60A5FA', role: 'Dark-mode link',  bg: 'var(--lp-link-dark)',     fg: 'var(--lp-dark-bg)' },
];
---
<DocsLayout title="Colors — Primary" description="Primary brand palette.">
  <div class="sg-swatches grid">
    {[...indigo, ...blog].map((s) => (
      <div class={`sg-swatch ${s.outline ? 'sg-swatch--outline' : ''}`} style={`background:${s.bg};color:${s.fg}`}>
        <div>
          <div class="sg-swatch-name">{s.name}</div>
          <div class="sg-swatch-role">{s.role}</div>
        </div>
        <div class="sg-swatch-hex">{s.hex}</div>
      </div>
    ))}
  </div>
</DocsLayout>

<style>
  .grid { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
</style>
