---
import DocsLayout from '../../layouts/DocsLayout.astro';

const shadows = [
  { name: 'Image rim', note: '25px · 15%', token: '--lp-shadow-img', kind: 'paper' },
  { name: 'Card resting', note: '4/16 · 6%', token: '--lp-shadow-card', kind: 'paper' },
  { name: 'Elevated', note: '14/36 · 10% ink', token: '--lp-shadow-elevated', kind: 'paper' },
  {
    name: 'Elevated hover',
    note: '18/42 · 14% ink',
    token: '--lp-shadow-elevated-hover',
    kind: 'lift',
  },
  {
    name: 'Button (legacy)',
    note: '4/15 · 40% indigo',
    token: '--lp-shadow-btn',
    kind: 'indigo-btn',
  },
];
---

<DocsLayout
  title="Spacing — Shadows"
  description="Elevation tokens — the executive-brief cards ride a resting elevation that lifts on hover. Click a token to copy it."
>
  <div class="sg-frame--row frame">
    {
      shadows.map((s) => (
        <div class="sg-stack">
          <div class={`tile tile--${s.kind}`} style={`box-shadow: var(${s.token})`} />
          <div class="sg-meta">
            {s.name}
            <small>{s.note}</small>
          </div>
          <button class="sg-copy" type="button" data-copy={`var(${s.token})`}>
            {s.token}
          </button>
        </div>
      ))
    }
  </div>
</DocsLayout>

<style>
  .frame {
    background: var(--lp-paper);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-8) var(--lp-space-6);
  }
  .tile {
    width: 88px;
    height: 64px;
    background: var(--lp-surface);
    border-radius: var(--lp-radius-lg);
  }
  .tile--lift {
    transform: translateY(-2px);
  }
  .tile--indigo-btn {
    background: var(--lp-indigo-500);
    border-radius: var(--lp-radius-md);
  }
</style>
