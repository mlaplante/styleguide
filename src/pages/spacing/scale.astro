---
import DocsLayout from '../../layouts/DocsLayout.astro';

const scale = [
  { token: '--lp-space-1',  step: '1',  px: 4   },
  { token: '--lp-space-2',  step: '2',  px: 8   },
  { token: '--lp-space-4',  step: '4',  px: 16  },
  { token: '--lp-space-6',  step: '6',  px: 24  },
  { token: '--lp-space-10', step: '10', px: 40  },
  { token: '--lp-space-18', step: '18', px: 72  },
  { token: '--lp-space-22', step: '22', px: 90,  note: 'section' },
  { token: '--lp-space-30', step: '30', px: 120, note: 'hero' },
];
---
<DocsLayout title="Spacing — Scale" description="Spacing scale used across components and sections. Click a token to copy it.">
  <div class="sg-frame--row">
    {scale.map((s) => (
      <div class="sg-stack">
        <div class="bar" style={`width: var(${s.token})`}></div>
        <div class="sg-meta">{s.step}<small>{s.px} px{s.note ? ` · ${s.note}` : ''}</small></div>
        <button class="sg-copy" type="button" data-copy={`var(${s.token})`}>{s.token}</button>
      </div>
    ))}
  </div>
</DocsLayout>

<style>
  .bar {
    background: var(--lp-indigo-500);
    height: 10px;
    border-radius: var(--lp-radius-sm);
  }
</style>
