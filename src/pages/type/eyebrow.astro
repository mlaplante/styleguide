---
import DocsLayout from '../../layouts/DocsLayout.astro';

const specimens = [
  { label: 'Portfolio eyebrow', text: 'about me', theme: 'portfolio' },
  { label: 'Portfolio eyebrow · alt', text: 'by the numbers', theme: 'portfolio' },
  { label: 'Blog eyebrow', text: 'latest posts', theme: 'blog' },
];
---

<DocsLayout
  title="Type — Eyebrow"
  description="Lowercase mono eyebrow underlined with an indigo (portfolio) or blue (blog) wash."
>
  <div class="sg-frame--stack">
    {
      specimens.map((s) => (
        <div>
          <div class="lbl">{s.label}</div>
          <span class={`eyebrow eyebrow--${s.theme}`}>{s.text}</span>
        </div>
      ))
    }
  </div>
</DocsLayout>

<style>
  .eyebrow {
    font-family: var(--lp-font-mono);
    font-size: 18px;
    font-weight: var(--lp-w-bold);
    line-height: var(--lp-lh-tight);
    color: rgba(0, 0, 0, 0.8);
    text-transform: lowercase;
    letter-spacing: var(--lp-ls-wider);
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  .eyebrow::after {
    content: '';
    position: absolute;
    bottom: 1px;
    left: 0;
    height: 5px;
    width: 100%;
    background: var(--lp-indigo-500);
    opacity: 0.4;
    z-index: -1;
  }
  .eyebrow--blog::after {
    background: var(--lp-blog-blue-500);
  }
  .lbl {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-100);
    margin-bottom: var(--lp-space-2);
  }
</style>
