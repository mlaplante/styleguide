---
import DocsLayout from '../../layouts/DocsLayout.astro';

const specimens = [
  { label: 'Section eyebrow', text: 'About Me' },
  { label: 'Section eyebrow · alt', text: 'By the Numbers' },
  { label: 'Blog eyebrow', text: 'Latest Posts' },
];
---

<DocsLayout
  title="Type — Eyebrow"
  description="Uppercase mono eyebrow prefixed with a short signal rule — the briefing-label motif. Replaces the old lowercase highlighter wash."
>
  <div class="sg-frame--stack">
    {
      specimens.map((s) => (
        <div>
          <div class="lbl">{s.label}</div>
          <span class="eyebrow">{s.text}</span>
        </div>
      ))
    }
  </div>
</DocsLayout>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--lp-space-3);
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    font-weight: var(--lp-w-bold);
    line-height: var(--lp-lh-normal);
    color: var(--lp-signal-deep);
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
    flex: 0 0 24px;
  }
  .lbl {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-100);
    margin-bottom: var(--lp-space-2);
  }
</style>
