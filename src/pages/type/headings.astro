---
import DocsLayout from '../../layouts/DocsLayout.astro';

const rows = [
  { label: 'H1', spec: '700 / 36 / -0.02em', cls: 'h1', text: 'Securing multi-cloud environments' },
  {
    label: 'H2',
    spec: '700 / 26 / -0.02em',
    cls: 'h2',
    text: 'Practical strategies for DevSecOps teams',
  },
  { label: 'H3', spec: '600 / 21 / -0.02em', cls: 'h3', text: 'Threat modelling in production' },
  {
    label: 'H4 · Card title',
    spec: '500 / 20 / -0.02em',
    cls: 'h4',
    text: 'Cloud Security Strategy',
  },
  { label: 'Stat', spec: '700 / 48 / 1em', cls: 'stat', text: '$800M' },
];
---

<DocsLayout
  title="Type — Headings"
  description="Heading specimens — display family is Space Grotesk with tight -0.02em tracking; the near-black navy ink carries the weight."
>
  <div class="sg-frame--stack">
    {
      rows.map((r) => (
        <div class="sg-row">
          <div class="sg-meta">
            {r.label}
            <small>{r.spec}</small>
          </div>
          <div class={r.cls}>{r.text}</div>
        </div>
      ))
    }
  </div>
</DocsLayout>

<style>
  .h1 {
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-lg);
    font-weight: var(--lp-w-bold);
    letter-spacing: var(--lp-ls-display);
    line-height: var(--lp-lh-snug);
    color: var(--lp-ink);
  }
  .h2 {
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-md);
    font-weight: var(--lp-w-bold);
    letter-spacing: var(--lp-ls-display);
    color: var(--lp-ink);
  }
  .h3 {
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-sm);
    font-weight: var(--lp-w-semibold);
    letter-spacing: var(--lp-ls-display);
    color: var(--lp-ink);
  }
  .h4 {
    font-family: var(--lp-font-display);
    font-size: 20px;
    font-weight: var(--lp-w-medium);
    letter-spacing: var(--lp-ls-display);
    color: var(--lp-ink);
  }
  .stat {
    font-family: var(--lp-font-display);
    font-size: 48px;
    font-weight: var(--lp-w-bold);
    letter-spacing: var(--lp-ls-tighter, -0.03em);
    line-height: var(--lp-lh-tight);
    color: var(--lp-ink);
  }
</style>
