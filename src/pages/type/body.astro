---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout
  title="Type — Body"
  description="Body copy specimens at the sizes you'll actually ship."
>
  <div class="sg-frame--stack">
    <div class="sg-row">
      <div class="sg-meta">Lead<small>Poppins 400 / 26 / 1.3</small></div>
      <div class="lead">I architect secure, scalable enterprise-grade technology solutions.</div>
    </div>
    <div class="sg-row">
      <div class="sg-meta">Body<small>Poppins 400 / 16 / 1.8</small></div>
      <div class="body">
        With over 15 years of distinguished professional experience, I spearhead mission-critical
        technology initiatives, delivering measurable impact across complex enterprise environments.
      </div>
    </div>
    <div class="sg-row">
      <div class="sg-meta">Meta<small>Roboto Mono 400 / 13</small></div>
      <div class="meta-mono">Mar 22, 2026 · 7 min read</div>
    </div>
    <div class="sg-row">
      <div class="sg-meta">Caption<small>Roboto Mono 400 / 11 / 1.5px</small></div>
      <div class="caption">YEARS IN ENTERPRISE SECURITY</div>
    </div>
  </div>
</DocsLayout>

<style>
  .lead {
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-md);
    font-weight: var(--lp-w-regular);
    color: var(--lp-fg-1);
    line-height: var(--lp-lh-snug);
    max-width: 60ch;
  }
  .body {
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-ui);
    line-height: var(--lp-lh-body);
    color: var(--lp-fg-2);
    max-width: 60ch;
  }
  .meta-mono {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-caption);
    color: var(--lp-fg-3);
  }
  .caption {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    color: var(--lp-fg-2);
  }
</style>
