---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Button from '../../components/brand/Button.astro';
import ServiceCard from '../../components/brand/ServiceCard.astro';
import Timeline from '../../components/brand/Timeline.astro';
import FloatingField from '../../components/brand/FloatingField.astro';

const experience = [
  {
    date: 'January 2026 — Present',
    org: 'Proforma',
    role: 'SVP of Information Security and Operations',
    body: 'Leading information security strategy and operational excellence across the organization. Establishing and maintaining comprehensive security frameworks, driving compliance with industry standards, and fostering a culture of security awareness.',
    current: true,
  },
  {
    date: 'April 2022 — January 2026',
    org: 'Proforma',
    role: 'Vice President of Technology',
    body: 'Led and managed technology teams while driving security and compliance innovation. Spearheaded strategic initiatives to enhance infrastructure security, implement robust compliance frameworks, and foster a culture of continuous improvement.',
  },
  {
    date: 'November 2021 — April 2022',
    org: 'Proforma',
    role: 'Director of Engineering',
    body: "Responsible for the continued development of the company's multi-million dollar business management solution. Led development teams in greenfield and remediation work, monthly trainings, and 1-1 coaching.",
  },
  {
    date: 'July 2019 — November 2021',
    org: 'Proforma',
    role: 'Software Development Manager',
    body: 'Led development teams in executing greenfield and remediation tasks, with monthly trainings with team members and coaching of team leaders.',
  },
  {
    date: 'June 2015 — February 2019',
    org: 'FireEye',
    role: 'Senior Web Engineer',
    body: "Created all Front End Development practices for FireEye's next-generation threat portal, FireEye Intelligence Portal, using React and Redux.",
  },
];
---

<DocsLayout title="UI Kit — Portfolio" description="Full portfolio composition.">
  <div class="p-root">
    <!-- ===== NAV ===== -->
    <nav class="p-nav">
      <div class="p-container p-nav-inner">
        <button
          class="p-menu-btn"
          type="button"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="portfolio-menu"
        >
          <span class="p-lines">
            <span class="p-l p-l1"></span>
            <span class="p-l p-l2"></span>
            <span class="p-l p-l3"></span>
          </span>
        </button>
        <button
          class="p-dark-toggle"
          type="button"
          aria-label="Switch to dark mode"
          aria-pressed="false"
        >
          ☀️
        </button>
        <div id="portfolio-menu" class="p-menu">
          <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">About</a></li>
            <li><a href="#">Services</a></li>
            <li><a href="#">Skills</a></li>
            <li><a href="#">Experience</a></li>
            <li><a href="#">Contact</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="#">Uses</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="p-hero" id="home">
      <div class="p-container">
        <div class="p-portrait" role="img" aria-label="Michael LaPlante — placeholder portrait">
          <div class="p-portrait-inner">
            <img
              src="/assets/laplante-logo-white.png"
              width="310"
              height="110"
              alt="La Plante Web Development"
              loading="lazy"
              decoding="async"
            />
            <span class="p-portrait-note">portrait placeholder</span>
          </div>
        </div>
        <h1 class="p-hero-name">I am <strong>Michael<br />La Plante</strong></h1>
        <p class="p-hero-tagline">SVP of Information Security and Operations</p>
        <div class="p-hero-cta">
          <Button href="#contact">Schedule a Consultation</Button>
        </div>
      </div>
    </section>

    <!-- ===== ABOUT ===== -->
    <section class="p-section" id="about">
      <div class="p-container">
        <div class="p-section-header">
          <h2 class="p-eyebrow">about me</h2>
        </div>
        <p class="p-about-lead">
          I'm an accomplished technology executive with comprehensive expertise in cybersecurity
          strategy, enterprise operations, and innovative software engineering.
        </p>
        <p class="p-about-body">
          With over 15 years of distinguished professional experience, I spearhead mission-critical
          technology initiatives as SVP of Information Security and Operations, delivering
          measurable impact across complex enterprise environments. My career trajectory showcases
          proven success in software engineering excellence, advanced security architecture,
          strategic team leadership, and operational transformation.
        </p>
        <p class="p-about-body">
          I architect and implement secure, scalable enterprise-grade technology solutions while
          cultivating high-performing teams that consistently exceed objectives and drive meaningful
          organizational change.
        </p>
        <ul class="p-social">
          <li><a href="#">LinkedIn</a></li>
          <li><a href="#">Facebook</a></li>
          <li><a href="#">Twitter</a></li>
          <li><a href="#">Github</a></li>
        </ul>
      </div>
    </section>

    <!-- ===== FUN FACTS ===== -->
    <section class="p-section p-bg-flat" id="funfacts">
      <div class="p-container">
        <div class="p-section-header">
          <h2 class="p-eyebrow">by the numbers</h2>
        </div>
        <div class="p-funfacts">
          <div class="p-funfact">
            <strong>$800M</strong>
            <span>Company secured</span>
          </div>
          <div class="p-funfact">
            <strong>15+</strong>
            <span>Years in enterprise security</span>
          </div>
          <div class="p-funfact">
            <strong>70+</strong>
            <span>Speaking engagements</span>
          </div>
          <div class="p-funfact">
            <strong>500+</strong>
            <span>Clients served</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SERVICES ===== -->
    <section class="p-section p-bg-paper" id="services">
      <div class="p-container">
        <div class="p-section-header">
          <h2 class="p-eyebrow">consulting services</h2>
        </div>
        <div class="p-service-grid">
          <ServiceCard title="Security Architecture">
            <svg
              slot="glyph"
              width="44"
              height="44"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M32 6 L52 14 V32 C52 46 42 54 32 58 C22 54 12 46 12 32 V14 Z"></path>
              <path d="M24 32 L30 38 L42 26"></path>
            </svg>
            Assess your infrastructure, identify gaps, and design defense-in-depth strategies tailored
            to your risk profile and compliance requirements.
          </ServiceCard>

          <ServiceCard title="Cloud Security Strategy">
            <svg
              slot="glyph"
              width="44"
              height="44"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M18 44 C10 44 6 38 6 32 C6 24 14 20 20 22 C22 14 30 10 38 14 C46 10 56 18 54 28 C60 30 60 42 52 44 Z"
              ></path>
            </svg>
            Build secure multi-cloud architectures across AWS, Azure, and GCP with zero-trust principles,
            least-privilege access, and continuous monitoring.
          </ServiceCard>

          <ServiceCard title="Compliance & Risk">
            <svg
              slot="glyph"
              width="44"
              height="44"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <rect x="14" y="28" width="36" height="28" rx="3"></rect>
              <path d="M20 28 V20 C20 14 26 8 32 8 C38 8 44 14 44 20 V28"></path>
              <circle cx="32" cy="40" r="3" fill="currentColor"></circle>
              <path d="M32 43 V49"></path>
            </svg>
            Navigate SOC 2, ISO 27001, HIPAA, and PCI-DSS with practical frameworks that satisfy auditors
            without slowing your teams down.
          </ServiceCard>

          <ServiceCard title="Engineering Leadership">
            <svg
              slot="glyph"
              width="44"
              height="44"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M24 44 C18 40 16 32 18 26 C22 14 38 12 44 22 C48 28 46 38 40 44 V50 H24 Z"
              ></path>
              <path d="M26 54 H38"></path>
              <path d="M28 58 H36"></path>
            </svg>
            Scale engineering organizations, establish DevSecOps practices, and build the security culture
            that keeps your company out of the headlines.
          </ServiceCard>
        </div>
        <div class="p-center">
          <Button href="#contact">Discuss Your Needs</Button>
        </div>
      </div>
    </section>

    <!-- ===== TIMELINE ===== -->
    <section class="p-section p-bg-flat" id="experience">
      <div class="p-container">
        <div class="p-section-header">
          <h2 class="p-eyebrow">my experience</h2>
        </div>
        <Timeline entries={experience} />
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section class="p-section p-bg-paper" id="contact">
      <div class="p-container">
        <div class="p-section-header">
          <h2 class="p-eyebrow">contact me</h2>
        </div>
        <form class="p-contact-form">
          <div class="p-form-group">
            <FloatingField label="Name" />
          </div>
          <div class="p-form-group">
            <FloatingField label="Email" type="email" />
          </div>
          <div class="p-form-group">
            <FloatingField label="Message" type="textarea" />
          </div>
          <Button type="submit">Send Message</Button>
        </form>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="p-footer">
      <div class="p-container">
        <p class="p-copyright">Copyright &copy; LaPlante Web Development 2006–2026.</p>
      </div>
    </footer>
  </div>
</DocsLayout>

<script is:inline>
  (function () {
    const nav = document.querySelector('.p-nav');
    const burg = document.querySelector('.p-menu-btn');
    const dark = document.querySelector('.p-dark-toggle');
    if (burg && nav) {
      burg.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        burg.setAttribute('aria-expanded', String(open));
        nav.querySelectorAll('.p-l').forEach((l) => l.classList.toggle('x'));
      });
    }
    if (dark) {
      dark.addEventListener('click', () => {
        const on = document.body.classList.toggle('p-dark');
        dark.textContent = on ? '🌙' : '☀️';
        dark.setAttribute('aria-pressed', String(on));
        dark.setAttribute('aria-label', on ? 'Switch to light mode' : 'Switch to dark mode');
      });
    }
    // Keep floating labels risen when a field has a value (focus is CSS-only).
    document
      .querySelectorAll('.p-contact-form .lp-field input, .p-contact-form .lp-field textarea')
      .forEach((el) => {
        const wrap = el.closest('.lp-field');
        const sync = () => wrap.classList.toggle('filled', !!el.value);
        el.addEventListener('input', sync);
        el.addEventListener('blur', sync);
        sync();
      });
  })();
</script>

<style is:global>
  /* Portfolio UI kit — composition-level styles. Component styles (buttons,
   service cards, timeline, floating fields) come from src/styles/components.css. */

  .p-root {
    background: var(--lp-paper);
    color: var(--lp-ink-900);
    font-family: var(--lp-font-display);
  }

  .p-container {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
  }

  /* ---------- Nav ---------- */
  .p-nav {
    position: sticky;
    top: 0;
    width: 100%;
    z-index: 99;
    background: transparent;
    padding: 12px 0;
  }
  .p-nav-inner {
    min-height: 52px;
  }

  .p-menu-btn {
    position: absolute;
    top: 14px;
    right: 12px;
    padding: 12px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 101;
  }
  .p-lines {
    width: 33px;
    height: 23px;
    display: block;
    position: relative;
  }
  .p-l {
    height: 3px;
    width: 100%;
    background: var(--lp-white);
    display: block;
    position: absolute;
    left: 0;
    transition: all 0.3s ease;
  }
  .p-l1 {
    top: 0;
  }
  .p-l2 {
    top: 10px;
  }
  .p-l3 {
    top: 20px;
  }
  .p-l.x {
    background: #202020;
  }
  .p-l1.x,
  .p-l3.x {
    top: 10px;
  }
  .p-l1.x {
    transform: rotate(-45deg);
  }
  .p-l3.x {
    transform: rotate(45deg);
  }
  .p-l2.x {
    opacity: 0;
  }

  .p-dark-toggle {
    position: absolute;
    top: 16px;
    right: 60px;
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 98;
    padding: 0;
    line-height: 1;
  }
  .p-dark-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.08);
  }

  .p-menu {
    position: absolute;
    top: 14px;
    right: -8px;
    width: 280px;
    border-radius: 4px;
    overflow: hidden;
    visibility: hidden;
    background: transparent;
    transition:
      box-shadow 0.6s ease,
      visibility 0s 0.6s;
    z-index: 100;
  }
  .p-menu::after {
    content: '';
    position: absolute;
    top: -600px;
    right: -600px;
    height: 1200px;
    width: 1200px;
    border-radius: 50%;
    background: #fff;
    z-index: -1;
    transform: scale(0);
    opacity: 0;
    transition:
      transform 0.6s ease,
      opacity 0.3s 0.3s ease;
  }
  .p-menu ul {
    list-style: none;
    padding: 10px 0;
    margin: 0 1px;
  }
  .p-menu li {
    transform: translateY(-15px);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  .p-menu li a {
    display: block;
    font-size: 14px;
    color: #808080;
    padding: 12px 25px;
    text-decoration: none;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .p-menu li a:hover {
    background: rgba(0, 0, 0, 0.04);
    color: #202020;
  }
  .p-nav.open .p-menu {
    visibility: visible;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.2);
    transition: box-shadow 0.6s 0.3s ease;
  }
  .p-nav.open .p-menu::after {
    transform: scale(1);
    opacity: 1;
    transition:
      transform 0.6s ease,
      opacity 0.6s ease;
  }
  .p-nav.open .p-menu li {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  /* ---------- Hero ---------- */
  .p-hero {
    background: var(--lp-indigo-500);
    padding: 120px 0 100px;
    box-shadow: 0 0 40px 0 rgba(0, 0, 0, 0.45);
    margin-top: -68px;
    padding-top: 168px;
  }
  .p-portrait {
    width: 220px;
    height: 220px;
    margin-bottom: 55px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 0 25px rgba(0, 0, 0, 0.15);
  }
  .p-portrait-inner {
    width: 100%;
    height: 100%;
    background: #303f8c;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .p-portrait-inner::before {
    content: '';
    position: absolute;
    inset: 10px;
    border-radius: 50%;
    border: 1.5px dashed rgba(255, 255, 255, 0.35);
    pointer-events: none;
  }
  .p-portrait-inner img {
    width: 64%;
    height: auto;
    object-fit: contain;
    opacity: 0.95;
    display: block;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.25));
  }
  .p-portrait-note {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--lp-font-mono);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }
  .p-hero-name {
    color: #fff;
    font-size: 68px;
    font-weight: 300;
    margin: 0;
    line-height: 1em;
    letter-spacing: 2px;
  }
  .p-hero-name strong {
    font-weight: 300;
  }
  .p-hero-tagline {
    font-family: var(--lp-font-mono);
    font-size: 20px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 10px;
    margin-bottom: 0;
    letter-spacing: 1px;
  }
  .p-hero-cta {
    margin-top: 30px;
  }

  /* ---------- Section scaffolding ---------- */
  .p-section {
    padding-top: 90px;
    padding-bottom: 10px;
  }
  .p-section.p-bg-paper {
    background: var(--lp-paper);
  }
  .p-section.p-bg-flat {
    background: var(--lp-paper);
  }
  .p-section:last-of-type {
    padding-bottom: 60px;
  }

  .p-section-header {
    margin-bottom: 40px;
  }
  .p-eyebrow {
    margin: 0;
    font-family: var(--lp-font-mono);
    font-size: 18px;
    font-weight: 700;
    line-height: 1em;
    color: rgba(0, 0, 0, 0.8);
    text-transform: lowercase;
    letter-spacing: 2px;
    position: relative;
    display: inline-block;
    z-index: 3;
  }
  .p-eyebrow::after {
    content: '';
    position: absolute;
    bottom: 1px;
    left: 0;
    height: 5px;
    width: 100%;
    background: var(--lp-indigo-500);
    opacity: 0.4;
    z-index: -1;
  }

  /* ---------- About ---------- */
  .p-about-lead {
    font-size: 44px;
    color: rgba(0, 0, 0, 0.8);
    margin: 0 0 20px;
    line-height: 1.15;
    font-weight: 400;
    max-width: 900px;
  }
  .p-about-body {
    color: rgba(0, 0, 0, 0.6);
    font-size: 14px;
    line-height: 1.8;
    margin: 0 0 15px;
    max-width: 780px;
  }
  .p-social {
    list-style: none;
    padding: 0;
    margin: 25px 0 0;
  }
  .p-social li {
    display: inline-block;
    margin-right: 25px;
  }
  .p-social a {
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 3px;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.6);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.3s;
  }
  .p-social a:hover {
    color: #202020;
  }

  /* ---------- Funfacts ---------- */
  .p-funfacts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .p-funfact strong {
    display: block;
    font-size: 66px;
    font-weight: 600;
    line-height: 1em;
    margin-bottom: 4px;
    color: var(--lp-ink-900);
  }
  .p-funfact span {
    font-family: var(--lp-font-mono);
    letter-spacing: 2px;
    font-size: 14px;
    color: rgba(0, 0, 0, 0.6);
  }

  /* ---------- Services ---------- */
  .p-service-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px 48px;
    margin-bottom: 40px;
  }
  .p-center {
    text-align: center;
    margin-top: 32px;
  }

  /* ---------- Contact ---------- */
  .p-contact-form {
    max-width: 640px;
  }
  .p-form-group {
    margin-bottom: 20px;
  }
  .p-contact-form .lp-field {
    margin-top: 5px;
  }
  .p-alert {
    background: rgba(63, 81, 181, 0.08);
    color: #202020;
    padding: 20px 24px;
    border-radius: 3px;
    font-size: 15px;
    max-width: 640px;
  }

  /* ---------- Footer ---------- */
  .p-footer {
    padding: 60px 0 90px;
  }
  .p-copyright {
    font-family: var(--lp-font-mono);
    font-size: 16px;
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
  }

  /* ---------- Dark mode (kit demo) ---------- */
  body.p-dark .p-root {
    background: #1a1a1a;
    color: #e0e0e0;
  }
  body.p-dark .p-hero {
    background: var(--lp-dark-bg-2);
  }
  body.p-dark .p-section.p-bg-paper,
  body.p-dark .p-section.p-bg-flat {
    background: #1a1a1a;
  }
  body.p-dark .p-eyebrow {
    color: rgba(255, 255, 255, 0.9);
  }
  body.p-dark .p-about-lead {
    color: #fff;
  }
  body.p-dark .p-about-body,
  body.p-dark .p-social a,
  body.p-dark .p-funfact span,
  body.p-dark .lp-service-copy,
  body.p-dark .lp-tl-role,
  body.p-dark .lp-tl-date,
  body.p-dark .lp-tl-body p,
  body.p-dark .p-copyright {
    color: #b0b0b0;
  }
  body.p-dark .p-funfact strong,
  body.p-dark .lp-service-title,
  body.p-dark .lp-tl-org {
    color: #fff;
  }
  body.p-dark .lp-service-glyph {
    background: rgba(99, 102, 241, 0.18);
  }
  body.p-dark .p-dark-toggle {
    border-color: rgba(255, 255, 255, 0.3);
  }
  body.p-dark .lp-field input,
  body.p-dark .lp-field textarea {
    color: #e0e0e0;
    border-bottom-color: #444;
  }
  body.p-dark .lp-field label {
    color: #999;
  }
  body.p-dark .p-alert {
    background: rgba(63, 81, 181, 0.15);
    color: #fff;
  }

  @media (max-width: 640px) {
    .p-hero {
      padding-top: 140px;
      padding-bottom: var(--lp-space-18);
    }
    .p-hero-name {
      font-size: clamp(48px, 15vw, var(--lp-t-hero));
    }
    .p-hero-tagline {
      font-size: var(--lp-t-ui);
    }
    .p-funfacts,
    .p-service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
