---
import DocsLayout from '../layouts/DocsLayout.astro';
---

<DocsLayout title="Logo" description="Primary brand mark on light and dark backgrounds.">
  <div class="grid">
    <div class="tile tile--light">
      <img
        src="/assets/laplante-logo.png"
        width="310"
        height="110"
        alt="La Plante Web Development"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="tile tile--dark">
      <img
        src="/assets/laplante-logo-white.png"
        width="310"
        height="110"
        alt="La Plante Web Development (reverse)"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</DocsLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--lp-space-3);
  }
  .tile {
    border-radius: var(--lp-radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--lp-space-10) var(--lp-space-6);
    min-height: 180px;
  }
  .tile--light {
    background: var(--lp-paper);
  }
  .tile--dark {
    background: var(--lp-ink);
  }
  .tile img {
    max-width: 100%;
    max-height: 140px;
    object-fit: contain;
  }
  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
