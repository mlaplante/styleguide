---
import DocsLayout from '../layouts/DocsLayout.astro';

const sections = [
  { href: '/logo', title: 'Logo', eyebrow: 'Foundations', blurb: 'Primary and alternate marks.', visual: 'logo' },
  { href: '/colors/primary', title: 'Colors', eyebrow: 'Foundations', blurb: 'Primary, accent, and neutral palettes.' },
  { href: '/type/hero', title: 'Type', eyebrow: 'Foundations', blurb: 'Hero, headings, body, and eyebrow specimens.' },
  { href: '/spacing/scale', title: 'Spacing', eyebrow: 'Foundations', blurb: 'Scale, radii, and elevation tokens.' },
  { href: '/components/buttons', title: 'Components', eyebrow: 'Library', blurb: 'Buttons, inputs, cards, and more.' },
  { href: '/ui-kits/blog', title: 'UI Kits', eyebrow: 'Compositions', blurb: 'Full blog and portfolio compositions.' },
];
---
<DocsLayout title="Style Guide" description="The La Plante Web Dev design system.">
  <div class="grid">
    {sections.map((s) => (
      <a class={`card${s.visual === 'logo' ? ' card--logo' : ''}`} href={s.href}>
        {s.visual === 'logo' && (
          <div class="logo-tile">
            <img src="/assets/laplante-logo.png" alt="La Plante Web Dev" />
          </div>
        )}
        <span class="eyebrow">{s.eyebrow}</span>
        <h3>{s.title}</h3>
        <p>{s.blurb}</p>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</DocsLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--lp-space-4);
  }
  .card {
    position: relative;
    display: block;
    padding: var(--lp-space-6);
    border: 1px solid var(--lp-border-subtle);
    border-radius: var(--lp-radius-xl);
    text-decoration: none;
    color: inherit;
    background: var(--lp-white);
    box-shadow: var(--lp-shadow-card);
    transition:
      transform var(--lp-dur-fast) var(--lp-ease),
      border-color var(--lp-dur-fast) var(--lp-ease),
      box-shadow var(--lp-dur-fast) var(--lp-ease);
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--lp-indigo-500);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--lp-dur) var(--lp-ease);
  }
  .card:hover {
    border-color: var(--lp-indigo-200);
    transform: translateY(-2px);
    box-shadow: var(--lp-shadow-btn);
  }
  .card:hover::before { transform: scaleY(1); }
  .card:hover .arrow { transform: translateX(4px); color: var(--lp-indigo-500); }

  .logo-tile {
    background: var(--lp-paper);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-8) var(--lp-space-5);
    margin: calc(var(--lp-space-6) * -1) calc(var(--lp-space-6) * -1) var(--lp-space-5);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    border-bottom: 1px solid var(--lp-border-subtle);
    border-top-left-radius: var(--lp-radius-xl);
    border-top-right-radius: var(--lp-radius-xl);
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
  .logo-tile img {
    max-width: 80%;
    max-height: 80px;
    object-fit: contain;
    transition: transform var(--lp-dur) var(--lp-ease);
  }
  .card--logo:hover .logo-tile img { transform: scale(1.03); }

  .eyebrow {
    display: block;
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-300);
    margin-bottom: var(--lp-space-3);
    font-weight: var(--lp-w-medium);
  }
  .card h3 {
    margin: 0 0 var(--lp-space-2);
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-md);
    font-weight: var(--lp-w-bold);
    letter-spacing: var(--lp-ls-snug);
    color: var(--lp-ink-900);
  }
  .card p {
    margin: 0;
    color: var(--lp-ink-400);
    font-size: var(--lp-t-caption);
    line-height: var(--lp-lh-normal);
  }
  .arrow {
    position: absolute;
    right: var(--lp-space-6);
    bottom: var(--lp-space-6);
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-ui);
    color: var(--lp-ink-200);
    transition: transform var(--lp-dur-fast) var(--lp-ease), color var(--lp-dur-fast) var(--lp-ease);
  }
</style>
