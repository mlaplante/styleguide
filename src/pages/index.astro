---
import DocsLayout from '../layouts/DocsLayout.astro';
import { landing } from '../data/nav';
---

<DocsLayout title="Style Guide" description="The La Plante Web Dev design system.">
  <div class="grid">
    {
      landing.map((s) => (
        <a class={`card card--${s.visual}`} href={s.href}>
          <div class="preview-tile" aria-hidden="true">
            {s.visual === 'logo' && (
              <img
                class="logo-img"
                src="/assets/laplante-logo.png"
                width="310"
                height="110"
                alt=""
                loading="lazy"
                decoding="async"
              />
            )}
            {s.visual === 'colors' && (
              <div class="color-row">
                <span style="background:var(--lp-ink)" />
                <span style="background:var(--lp-ink-2)" />
                <span style="background:var(--lp-signal)" />
                <span style="background:var(--lp-signal-deep)" />
                <span style="background:var(--lp-slate)" />
                <span style="background:var(--lp-surface);border:1px solid var(--lp-line-2)" />
              </div>
            )}
            {s.visual === 'type' && (
              <div class="type-demo">
                <span class="type-aa">Aa</span>
                <div class="type-stack">
                  <span class="type-eyebrow">SPACE GROTESK · POPPINS · ROBOTO MONO</span>
                  <span class="type-head">Headline</span>
                  <span class="type-body">Supporting copy set in body.</span>
                </div>
              </div>
            )}
            {s.visual === 'spacing' && (
              <div class="spacing-demo">
                <span style="width:12px" />
                <span style="width:20px" />
                <span style="width:32px" />
                <span style="width:48px" />
                <span style="width:72px" />
              </div>
            )}
            {s.visual === 'motion' && (
              <div class="motion-demo">
                <span class="motion-dot motion-dot--fast" />
                <span class="motion-dot motion-dot--base" />
                <span class="motion-dot motion-dot--slow" />
              </div>
            )}
            {s.visual === 'components' && (
              <div class="components-demo">
                <span class="btn-demo">Schedule a Call</span>
                <span class="btn-demo btn-demo--ghost">Learn More</span>
              </div>
            )}
            {s.visual === 'ui-kits' && (
              <div class="kit-demo">
                <span class="kit-bar" />
                <div class="kit-body">
                  <span class="kit-line kit-line--lg" />
                  <span class="kit-line" />
                  <span class="kit-line kit-line--sm" />
                </div>
              </div>
            )}
          </div>
          <span class="eyebrow">{s.eyebrow}</span>
          <h2>{s.title}</h2>
          <p>{s.blurb}</p>
          <span class="arrow" aria-hidden="true">
            →
          </span>
        </a>
      ))
    }
  </div>
</DocsLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--lp-space-4);
  }
  .card {
    position: relative;
    display: block;
    padding: var(--lp-space-6);
    border: 1px solid var(--lp-border-subtle);
    border-radius: var(--lp-radius-xl);
    text-decoration: none;
    color: inherit;
    background: var(--lp-white);
    box-shadow: var(--lp-shadow-card);
    transition:
      transform var(--lp-dur-fast) var(--lp-ease),
      border-color var(--lp-dur-fast) var(--lp-ease),
      box-shadow var(--lp-dur-fast) var(--lp-ease);
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--lp-signal);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--lp-dur) var(--lp-ease);
  }
  .card:hover {
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: var(--lp-shadow-elevated-hover);
  }
  .card:hover::before {
    transform: scaleY(1);
  }
  .card:hover .arrow {
    transform: translateX(4px);
    color: var(--lp-signal-deep);
  }

  .preview-tile {
    background: var(--lp-paper);
    padding: var(--lp-space-6) var(--lp-space-5);
    margin: calc(var(--lp-space-6) * -1) calc(var(--lp-space-6) * -1) var(--lp-space-5);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    border-bottom: 1px solid var(--lp-border-subtle);
    overflow: hidden;
  }

  /* Logo */
  .logo-img {
    max-width: 80%;
    max-height: 80px;
    object-fit: contain;
    transition: transform var(--lp-dur) var(--lp-ease);
  }
  .card--logo:hover .logo-img {
    transform: scale(1.03);
  }

  /* Colors */
  .color-row {
    display: flex;
    gap: var(--lp-space-2);
    width: 80%;
  }
  .color-row span {
    flex: 1;
    aspect-ratio: 1 / 1;
    border-radius: var(--lp-radius-md);
    box-shadow: var(--lp-shadow-card);
    transition: transform var(--lp-dur-fast) var(--lp-ease);
  }
  .card--colors:hover .color-row span {
    transform: translateY(-2px);
  }

  /* Type */
  .type-demo {
    display: flex;
    align-items: center;
    gap: var(--lp-space-5);
    width: 100%;
    padding: 0 var(--lp-space-4);
  }
  .type-aa {
    font-family: var(--lp-font-display);
    font-size: 64px;
    font-weight: var(--lp-w-bold);
    line-height: 1;
    letter-spacing: var(--lp-ls-display);
    color: var(--lp-ink);
  }
  .type-stack {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .type-eyebrow {
    font-family: var(--lp-font-mono);
    font-size: 9px;
    letter-spacing: var(--lp-ls-wider);
    color: var(--lp-ink-300);
  }
  .type-head {
    font-family: var(--lp-font-display);
    font-size: 18px;
    font-weight: var(--lp-w-medium);
    color: var(--lp-ink);
    letter-spacing: var(--lp-ls-display);
  }
  .type-body {
    font-family: var(--lp-font-body);
    font-size: 12px;
    color: var(--lp-slate);
    line-height: var(--lp-lh-normal);
  }

  /* Spacing */
  .spacing-demo {
    display: flex;
    flex-direction: column;
    gap: var(--lp-space-2);
    align-items: flex-start;
  }
  .spacing-demo span {
    height: 8px;
    background: var(--lp-signal);
    border-radius: var(--lp-radius-sm);
    transition: transform var(--lp-dur-fast) var(--lp-ease);
  }
  .card--spacing:hover .spacing-demo span {
    transform: scaleX(1.05);
    transform-origin: left;
  }

  /* Motion */
  .motion-demo {
    display: flex;
    gap: var(--lp-space-3);
    align-items: center;
  }
  .motion-dot {
    width: 14px;
    height: 14px;
    border-radius: var(--lp-radius-full);
    background: var(--lp-signal);
    transition: transform var(--lp-dur) var(--lp-ease);
  }
  .motion-dot--fast {
    transition-duration: var(--lp-dur-fast);
  }
  .motion-dot--base {
    transition-duration: var(--lp-dur);
  }
  .motion-dot--slow {
    transition-duration: var(--lp-dur-slow);
  }
  .card--motion:hover .motion-dot {
    transform: translateX(40px);
  }
  .card--motion:hover .motion-dot--fast {
    background: var(--lp-accent-pink);
  }
  .card--motion:hover .motion-dot--base {
    background: var(--lp-accent-teal);
  }
  .card--motion:hover .motion-dot--slow {
    background: var(--lp-accent-purple);
  }

  /* Components */
  .components-demo {
    display: flex;
    gap: var(--lp-space-3);
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-demo {
    display: inline-block;
    padding: 10px 22px;
    background: var(--lp-signal);
    color: var(--lp-ink);
    border-radius: var(--lp-radius-md);
    font-family: var(--lp-font-display);
    font-weight: var(--lp-w-semibold);
    font-size: 12px;
    letter-spacing: 0.2px;
    border: 2px solid var(--lp-signal);
    box-shadow: none;
  }
  .btn-demo--ghost {
    background: transparent;
    color: var(--lp-ink);
    border-color: currentColor;
    box-shadow: none;
  }

  /* UI Kits */
  .kit-demo {
    width: 85%;
    background: var(--lp-white);
    border-radius: var(--lp-radius-md);
    box-shadow: var(--lp-shadow-card);
    overflow: hidden;
    border: 1px solid var(--lp-border-subtle);
  }
  .kit-bar {
    display: block;
    height: 14px;
    background: var(--lp-ink);
  }
  .kit-body {
    padding: var(--lp-space-3) var(--lp-space-4);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .kit-line {
    height: 6px;
    background: var(--lp-paper-3);
    border-radius: var(--lp-radius-sm);
    width: 75%;
  }
  .kit-line--lg {
    width: 90%;
    height: 8px;
    background: var(--lp-ink-500);
  }
  .kit-line--sm {
    width: 50%;
  }

  .eyebrow {
    display: block;
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-300);
    margin-bottom: var(--lp-space-3);
    font-weight: var(--lp-w-medium);
  }
  .card h2 {
    margin: 0 0 var(--lp-space-2);
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-md);
    font-weight: var(--lp-w-semibold);
    letter-spacing: var(--lp-ls-display);
    color: var(--lp-ink);
  }
  .card p {
    margin: 0;
    color: var(--lp-ink-400);
    font-size: var(--lp-t-caption);
    line-height: var(--lp-lh-normal);
  }
  .arrow {
    position: absolute;
    right: var(--lp-space-6);
    bottom: var(--lp-space-6);
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-ui);
    color: var(--lp-ink-200);
    transition:
      transform var(--lp-dur-fast) var(--lp-ease),
      color var(--lp-dur-fast) var(--lp-ease);
  }
</style>
