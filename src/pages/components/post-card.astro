---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PostCard from '../../components/brand/PostCard.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';

const snippet = `<a class="lp-post-card" href="#">
  <div class="lp-post-meta">
    <span class="lp-pill lp-pill--blog">dev-session</span>
    <span class="lp-post-date">Apr 16, 2026</span>
    <span class="lp-post-sep">·</span>
    <span class="lp-post-read">7 min read</span>
  </div>
  <h3 class="lp-post-title">Post title</h3>
  <p class="lp-post-excerpt">One-or-two sentence excerpt.</p>
</a>

<!-- Styles: .lp-post-card in src/styles/components.css -->`;
---

<DocsLayout title="Post Card" description="Blog post card used in the writing list.">
  <div class="frame">
    <PostCard
      category="dev-session"
      date="Apr 16, 2026"
      readTime="7 min read"
      title="Netlify to Cloudflare Workers contact form"
      excerpt="Migrating the portfolio's contact form off Netlify Functions and onto a Cloudflare Worker — with Turnstile, rate-limiting, and zero Netlify-specific code left behind."
    />
  </div>
  <CodeSnippet code={snippet} />
</DocsLayout>

<style>
  .frame {
    background: var(--lp-paper-2);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-8);
    display: flex;
    justify-content: center;
  }
  .frame :global(.lp-post-card) {
    max-width: 460px;
    width: 100%;
  }
</style>
