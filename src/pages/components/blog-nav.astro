---
import DocsLayout from '../../layouts/DocsLayout.astro';
---
<DocsLayout title="Blog Nav" description="Sticky blog nav with a scroll-driven reading-progress bar.">
  <div class="frame">
    <div class="nav">
      <a class="brand" href="#">Michael LaPlante</a>
      <div class="links">
        <a class="link" href="#">blog</a>
        <a class="link" href="#">about</a>
        <a class="link" href="#">contact</a>
      </div>
    </div>
    <div class="progress"></div>
    <div class="body-pad">
      <div class="caption">Sticky blog nav · reading progress bar (scroll-timeline, falls back to a static 38% bar)</div>
    </div>
  </div>
</DocsLayout>

<style>
  .frame {
    background: var(--lp-paper-2);
    border-radius: var(--lp-radius-lg);
    overflow: hidden;
  }
  .nav {
    background: linear-gradient(135deg, var(--lp-blog-blue-500) 0%, var(--lp-blog-blue-600) 100%);
    padding: var(--lp-space-4) var(--lp-space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--lp-shadow-blog-nav);
  }
  .brand,
  .link {
    color: var(--lp-white);
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-meta);
    letter-spacing: var(--lp-ls-wide);
    text-transform: lowercase;
    text-decoration: none;
  }
  .brand { font-weight: var(--lp-w-bold); letter-spacing: 1.5px; }
  .links { display: flex; gap: var(--lp-space-6); }
  /* Static fallback width so the bar is always visible; scroll-timeline overrides in supporting browsers. */
  .progress { height: 3px; background: var(--lp-link-dark); width: 38%; }
  @supports (animation-timeline: scroll()) {
    .progress {
      width: 0;
      animation: progress-scroll linear;
      animation-timeline: scroll(root);
    }
    @keyframes progress-scroll { to { width: 100%; } }
  }
  .body-pad {
    padding: var(--lp-space-4) var(--lp-space-6) var(--lp-space-6);
    display: flex;
    align-items: center;
  }
  .caption {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-100);
  }
</style>
