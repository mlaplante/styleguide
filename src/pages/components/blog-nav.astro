---
import DocsLayout from '../../layouts/DocsLayout.astro';
import BlogNav from '../../components/brand/BlogNav.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';

const snippet = `<nav class="lp-blog-nav is-sticky">
  <div class="lp-blog-nav-inner">
    <a class="lp-blog-brand" href="#">Michael LaPlante</a>
    <ul class="lp-blog-links">
      <li><a class="active" href="#">blog</a></li>
      <li><a href="#">about</a></li>
      <li><a href="#">contact</a></li>
    </ul>
  </div>
  <div class="lp-blog-progress"></div>
</nav>

<!-- Styles: .lp-blog-nav in src/styles/components.css.
     Drop is-sticky to render in-flow. The progress bar is scroll-driven
     (animation-timeline) with a static 38% fallback. -->`;
---

<DocsLayout
  title="Blog Nav"
  description="Sticky blog nav with a scroll-driven reading-progress bar."
>
  <div class="frame">
    <BlogNav
      brand="Michael LaPlante"
      links={[{ label: 'blog', active: true }, { label: 'about' }, { label: 'contact' }]}
    />
    <div class="body-pad">
      <div class="caption">
        Sticky blog nav · reading progress bar (scroll-timeline, falls back to a static 38% bar)
      </div>
    </div>
  </div>
  <CodeSnippet code={snippet} />
</DocsLayout>

<style>
  .frame {
    background: var(--lp-paper-2);
    border-radius: var(--lp-radius-lg);
    overflow: hidden;
  }
  .body-pad {
    padding: var(--lp-space-4) var(--lp-space-6) var(--lp-space-6);
    display: flex;
    align-items: center;
  }
  .caption {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-100);
  }
</style>
