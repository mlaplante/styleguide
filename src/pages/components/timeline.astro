---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Timeline from '../../components/brand/Timeline.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';

const entries = [
  {
    date: 'January 2026 — Present',
    org: 'Proforma',
    role: 'SVP of Information Security and Operations',
    current: true,
  },
  { date: 'April 2022 — January 2026', org: 'Proforma', role: 'Vice President of Technology' },
  { date: 'Nov 2021 — April 2022', org: 'Proforma', role: 'Director of Engineering' },
];

const snippet = `<ul class="lp-timeline">
  <li class="current">
    <div class="lp-tl-date">January 2026 — Present</div>
    <div class="lp-tl-body">
      <h4 class="lp-tl-org">Proforma</h4>
      <span class="lp-tl-role">SVP of Information Security and Operations</span>
      <p>Optional supporting paragraph.</p>
    </div>
  </li>
  <!-- …more <li> entries (omit class="current") -->
</ul>

<!-- Styles: .lp-timeline in src/styles/components.css -->`;
---

<DocsLayout title="Timeline" description="Career timeline — rule, dot, current-position indicator.">
  <Timeline entries={entries} />
  <CodeSnippet code={snippet} />
</DocsLayout>
