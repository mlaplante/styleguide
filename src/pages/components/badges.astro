---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';

const snippet = `<span class="lp-pill lp-pill--blog">dev-session</span>
<span class="lp-pill lp-pill--indigo">thought-leadership</span>
<span class="lp-pill lp-pill--teal">case-study</span>
<span class="lp-pill lp-pill--purple">talk</span>

<span class="lp-status lp-status--ok">Operational</span>
<span class="lp-status lp-status--warn">Degraded</span>
<span class="lp-status lp-status--err">Outage</span>
<span class="lp-status lp-status--info">In review</span>

<code class="lp-t-code">--lp-radius-md</code>

<!-- Styles: .lp-pill / .lp-status in src/styles/components.css;
     .lp-t-code in src/styles/global.css -->`;
---

<DocsLayout title="Badges" description="Category pills, status badges, and inline code chips.">
  <section class="set">
    <h2>Category pills · blog</h2>
    <div class="row">
      <span class="lp-pill lp-pill--blog">dev-session</span>
      <span class="lp-pill lp-pill--indigo">thought-leadership</span>
      <span class="lp-pill lp-pill--teal">case-study</span>
      <span class="lp-pill lp-pill--purple">talk</span>
    </div>
  </section>

  <section class="set">
    <h2>Status</h2>
    <div class="row">
      <span class="lp-status lp-status--ok">Operational</span>
      <span class="lp-status lp-status--warn">Degraded</span>
      <span class="lp-status lp-status--err">Outage</span>
      <span class="lp-status lp-status--info">In review</span>
    </div>
  </section>

  <section class="set">
    <h2>Inline code</h2>
    <p class="prose">
      Set <code class="lp-t-code">--lp-radius-md</code> on CTA buttons and
      <code class="lp-t-code">--lp-radius-xl</code> on cards. Article body inherits
      <code class="lp-t-code">var(--lp-font-display)</code>.
    </p>
  </section>

  <CodeSnippet code={snippet} />
</DocsLayout>

<style>
  .set + .set {
    margin-top: var(--lp-space-6);
  }
  h2 {
    font-family: var(--lp-font-mono);
    font-size: 10px;
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-300);
    margin: 0 0 var(--lp-space-3);
    font-weight: var(--lp-w-bold);
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--lp-space-2);
  }
  .prose {
    font-family: var(--lp-font-display);
    font-size: var(--lp-t-base);
    line-height: var(--lp-lh-body);
    color: var(--lp-fg-2);
    max-width: 60ch;
    margin: 0;
  }
</style>
