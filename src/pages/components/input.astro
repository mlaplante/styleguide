---
import DocsLayout from '../../layouts/DocsLayout.astro';
import FloatingField from '../../components/brand/FloatingField.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';

const snippet = `<div class="lp-field">
  <input type="text" placeholder=" " />
  <label>Name</label>
</div>

<!-- Styles: .lp-field in src/styles/components.css.
     Focus is handled by :focus-within; toggle the "filled" class with JS
     when the field has a value so the label stays risen:
       field.classList.toggle('filled', !!input.value) -->`;
---
<DocsLayout title="Input" description="Underlined text input with a floating-label pattern (Material-ish, custom).">
  <div class="sg-frame--stack">
    <div>
      <div class="lbl">Empty</div>
      <FloatingField label="Name" />
    </div>
    <div>
      <div class="lbl">Focused</div>
      <FloatingField label="Email" state="focus" />
    </div>
    <div>
      <div class="lbl">Filled</div>
      <FloatingField label="Email" state="filled" value="michael@laplante.dev" />
    </div>
    <div>
      <div class="lbl">Textarea</div>
      <FloatingField label="Message" type="textarea" state="filled" value="Tell us about the engagement." />
    </div>
  </div>
  <CodeSnippet code={snippet} />
</DocsLayout>

<style>
  .lbl {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-100);
    margin-bottom: var(--lp-space-2);
  }
  .sg-frame--stack :global(.lp-field) { max-width: 420px; }
</style>
