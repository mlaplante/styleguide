---
import DocsLayout from '../../layouts/DocsLayout.astro';
---
<DocsLayout title="Buttons" description="Primary button styles.">
<div class="wrap">
  <div class="group"><div class="lbl">Primary</div><a class="btn">Schedule a Consultation</a></div>
  <div class="group"><div class="lbl">Hover</div><a class="btn hover">Discuss Your Needs</a></div>
  <div class="group"><div class="lbl">Compact</div><a class="btn small">View All Posts</a></div>
</div>
</DocsLayout>

<style is:global>
  html,body{margin:0;background:#F1F1F1;font-family:var(--lp-font-display);color:var(--lp-ink-900)}
  .wrap{padding:30px 34px;height:100%;box-sizing:border-box;display:flex;align-items:center;gap:22px;flex-wrap:wrap}
  .lbl{font-family:var(--lp-font-mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:#9ca3af;margin-bottom:6px}
  .group{display:flex;flex-direction:column;align-items:flex-start;gap:2px}
  .btn{display:inline-block;padding:16px 36px;background:#3F51B5;color:#fff;text-decoration:none;border-radius:6px;font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:1.5px;border:2px solid #3F51B5;box-shadow:0 4px 15px rgba(63,81,181,0.4);cursor:pointer;font-family:inherit}
  .btn.hover{background:transparent;color:#3F51B5;transform:translateY(-3px);box-shadow:0 10px 30px rgba(63,81,181,0.5)}
  .btn.ghost{background:transparent;color:#3F51B5;box-shadow:none}
  .btn.small{padding:10px 22px;font-size:12px;letter-spacing:1.2px;border-radius:4px;box-shadow:none}
</style>
