---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Button from '../../components/brand/Button.astro';
import CodeSnippet from '../../components/CodeSnippet.astro';

const snippet = `<a class="lp-btn" href="#">Schedule a Consultation</a>
<a class="lp-btn lp-btn--ghost" href="#">Learn More</a>
<a class="lp-btn lp-btn--sm" href="#">View All Posts</a>

<!-- Styles: .lp-btn in src/styles/components.css -->`;
---

<DocsLayout title="Buttons" description="Primary CTA, hover state, and compact list-action button.">
  <div class="frame">
    <div class="group">
      <div class="lbl">Primary</div>
      <Button href="#">Schedule a Consultation</Button>
    </div>
    <div class="group">
      <div class="lbl">Hover (lifted)</div>
      <Button href="#" lifted>Discuss Your Needs</Button>
    </div>
    <div class="group">
      <div class="lbl">Ghost</div>
      <Button href="#" variant="ghost">Learn More</Button>
    </div>
    <div class="group">
      <div class="lbl">Compact</div>
      <Button href="#" variant="sm">View All Posts</Button>
    </div>
  </div>
  <CodeSnippet code={snippet} />
</DocsLayout>

<style>
  .frame {
    background: var(--lp-paper);
    border-radius: var(--lp-radius-lg);
    padding: var(--lp-space-8);
    display: flex;
    align-items: center;
    gap: var(--lp-space-6);
    flex-wrap: wrap;
  }
  .lbl {
    font-family: var(--lp-font-mono);
    font-size: var(--lp-t-micro);
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-100);
    margin-bottom: var(--lp-space-2);
  }
  .group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
</style>
