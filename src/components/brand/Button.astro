---
/**
 * Brand CTA button. Styles live in src/styles/components.css (.lp-btn).
 * Renders an <a> when href is given, otherwise a <button>.
 */
export interface Props {
  href?: string;
  type?: 'button' | 'submit';
  variant?: 'primary' | 'ghost' | 'sm';
  /** Force the lifted hover state (for specimen pages). */
  lifted?: boolean;
}
const { href, type = 'button', variant = 'primary', lifted = false } = Astro.props;
const classes = ['lp-btn', variant !== 'primary' && `lp-btn--${variant}`, lifted && 'is-lifted']
  .filter(Boolean)
  .join(' ');
---

{
  href ? (
    <a class={classes} href={href}>
      <slot />
    </a>
  ) : (
    <button class={classes} type={type}>
      <slot />
    </button>
  )
}
