---
/**
 * Underlined input with floating label (Material-ish, custom).
 * Styles live in src/styles/components.css (.lp-field).
 * Real focus uses :focus-within; add the "filled" class (via JS) when the
 * field has a value so the label stays risen. The `state` prop forces a
 * state for static specimens.
 */
export interface Props {
  label: string;
  type?: 'text' | 'email' | 'textarea';
  value?: string;
  rows?: number;
  state?: 'focus' | 'filled';
}
const { label, type = 'text', value, rows = 3, state } = Astro.props;
const classes = `lp-field${state ? ` ${state}` : ''}`;
---

<div class={classes}>
  {
    type === 'textarea' ? (
      <textarea rows={rows} placeholder=" ">
        {value}
      </textarea>
    ) : (
      <input type={type} value={value} placeholder=" " />
    )
  }
  <label>{label}</label>
</div>
