---
const groups = [
  {
    title: 'Foundations',
    items: [
      { href: '/logo', label: 'Logo' },
      { href: '/colors/primary', label: 'Colors — Primary' },
      { href: '/colors/accent-palette', label: 'Colors — Accent Palette' },
      { href: '/colors/neutrals', label: 'Colors — Neutrals' },
      { href: '/type/hero', label: 'Type — Hero' },
      { href: '/type/headings', label: 'Type — Headings' },
      { href: '/type/body', label: 'Type — Body' },
      { href: '/type/eyebrow', label: 'Type — Eyebrow' },
      { href: '/spacing/scale', label: 'Spacing — Scale' },
      { href: '/spacing/radii', label: 'Spacing — Radii' },
      { href: '/spacing/shadows', label: 'Spacing — Shadows' },
    ],
  },
  {
    title: 'Components',
    items: [
      { href: '/components/buttons', label: 'Buttons' },
      { href: '/components/input', label: 'Input' },
      { href: '/components/blog-nav', label: 'Blog Nav' },
      { href: '/components/post-card', label: 'Post Card' },
      { href: '/components/service', label: 'Service' },
      { href: '/components/timeline', label: 'Timeline' },
    ],
  },
  {
    title: 'UI Kits',
    items: [
      { href: '/ui-kits/blog', label: 'Blog' },
      { href: '/ui-kits/portfolio', label: 'Portfolio' },
    ],
  },
];

const current = Astro.url.pathname.replace(/\/$/, '');
---
<aside class="sidebar">
  <nav>
    {groups.map((g) => (
      <section>
        <h2>{g.title}</h2>
        <ul>
          {g.items.map((it) => {
            const active = current === it.href;
            return (
              <li>
                <a href={it.href} class={active ? 'active' : ''}>{it.label}</a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    border-right: 1px solid var(--lp-border-subtle);
    padding: var(--lp-space-6) var(--lp-space-4);
    background: var(--lp-paper-2);
    position: sticky;
    top: var(--topbar-h);
    align-self: start;
    max-height: calc(100vh - var(--topbar-h));
    overflow-y: auto;
    font-family: var(--lp-font-display);
  }
  nav section + section { margin-top: var(--lp-space-6); }
  h2 {
    font-family: var(--lp-font-mono);
    font-size: 10px;
    letter-spacing: var(--lp-ls-wider);
    text-transform: uppercase;
    color: var(--lp-ink-300);
    margin: 0 0 var(--lp-space-2) var(--lp-space-2);
    font-weight: var(--lp-w-bold);
  }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin: 0; }
  a {
    display: block;
    padding: var(--lp-space-2) var(--lp-space-3);
    border-radius: var(--lp-radius-md);
    color: var(--lp-ink-500);
    text-decoration: none;
    font-size: 13px;
    font-weight: var(--lp-w-medium);
    transition: background var(--lp-dur-fast) var(--lp-ease), color var(--lp-dur-fast) var(--lp-ease);
  }
  a:hover { background: var(--lp-indigo-100); color: var(--lp-indigo-700); }
  a.active {
    background: var(--lp-indigo-500);
    color: var(--lp-white);
    box-shadow: var(--lp-shadow-btn);
  }

  @media (max-width: 768px) {
    .sidebar { position: static; max-height: none; border-right: none; border-bottom: 1px solid var(--lp-border-subtle); }
  }
</style>
